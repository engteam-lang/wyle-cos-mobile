<?xml version="1.0" encoding="utf-8"?>
<!--
  Wyle adaptive-icon foreground.

  Adaptive-icon viewport  : 108 × 108 dp
  Guaranteed visible zone : centre 72 × 72 dp  (18 dp inset on every side)
  Our circle at scale 0.72: radius 36 × 0.72 ≈ 26 dp  →  fits 54±26 = 28–80 dp
                            that leaves ≈10 dp clear margin inside the safe zone.
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!--
      Scale everything to 72 % around the centre (54, 54).
      This shrinks the teal circle from radius 36 → ≈26 dp,
      keeping it well clear of the adaptive-icon mask on all launchers.
    -->
    <group
        android:pivotX="54"
        android:pivotY="54"
        android:scaleX="0.72"
        android:scaleY="0.72">

        <!-- Teal circle -->
        <path
            android:fillColor="#1B998B"
            android:pathData="M54,18 a36,36 0 1,1 0,72 a36,36 0 1,1 0,-72z"/>

        <!-- "W" letterform in white -->
        <path
            android:fillColor="#FFFFFF"
            android:pathData="M36,38 L42,38 L54,62 L66,38 L72,38 L57,74 L54,68 L51,74 Z"/>

    </group>

</vector>
