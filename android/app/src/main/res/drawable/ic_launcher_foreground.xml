<?xml version="1.0" encoding="utf-8"?>
<!--
  Adaptive-icon foreground wrapper.

  flutter_launcher_icons generates @mipmap/ic_launcher_foreground (a PNG
  that fills the full 108 dp adaptive-icon canvas).  Android's launcher
  mask clips roughly 18 dp on every side, so the outer edges of the logo
  are cut off on circular / squircle masks.

  This <inset> adds 15 % padding on all four sides, pulling the logo
  well inside the guaranteed visible safe-zone.  Referenced from
  mipmap-anydpi-v26/ic_launcher.xml (patched in CI after flutter_launcher_icons
  runs so that the mipmap PNG already exists).
-->
<inset xmlns:android="http://schemas.android.com/apk/res/android"
    android:drawable="@mipmap/ic_launcher_foreground"
    android:inset="15%" />
