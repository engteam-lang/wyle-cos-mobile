{
    "manifest_version": 3,
    "name": "Wyle Buddy",
    "version": "1.0",
    "description": "A Flutter app running in your browser's sidebar.",
    "permissions": [
        "sidePanel",
        "tabs",
        "activeTab",
        "storage",
        "activeTab",
        "scripting"
    ],
    "background": {
        "service_worker": "background.js"
    },
    "action": {
        "default_title": "Open Sidebar"
    },
    "side_panel": {
        "default_path": "sidepanel.html"
    },
    "content_security_policy": {
        "extension_pages": "script-src 'self' 'wasm-unsafe-eval'; object-src 'self';"
    },
    "web_accessible_resources": [
        {
            "resources": [
                "flutter/*",
                "flutter/canvaskit/*"
            ],
            "matches": [
                "<all_urls>"
            ]
        }
    ]
}